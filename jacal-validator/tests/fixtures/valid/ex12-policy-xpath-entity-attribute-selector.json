{
  "Policy": {
    "PolicyId": "urn:example:policy:entity-attr-selector",
    "Version": "1.0",
    "CombiningAlgId": "urn:oasis:names:tc:acal:1.0:combining-algorithm:deny-unless-permit",
    "PolicyDefaults": [
      {
        "XPathPolicyDefaults": {
          "XPathVersion": "urn:example:xpath:1.0"
        }
      }
    ],
    "CombinerInput": [
      {
        "Rule": {
          "Id": "permit-by-entity",
          "Effect": "Permit",
          "Condition": {
            "XPathEntityAttributeSelector": {
              "Path": "/entity/@category",
              "DataType": "urn:oasis:names:tc:acal:1.0:data-type:string",
              "MustBePresent": false,
              "ContextSelectorId": "urn:example:jacal:selector:entity-node",
              "Expression": {
                "AttributeDesignator": {
                  "Category": "urn:oasis:names:tc:acal:1.0:subject-category:access-subject",
                  "AttributeId": "urn:example:jacal:subject:entity-ref",
                  "DataType": "urn:oasis:names:tc:acal:1.0:data-type:string",
                  "MustBePresent": false
                }
              }
            }
          }
        }
      }
    ]
  }
}
